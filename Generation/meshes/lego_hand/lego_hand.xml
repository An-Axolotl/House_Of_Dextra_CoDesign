<?xml version='1.0' encoding='utf-8'?>
<mujoco model="hand_scene">
  <compiler angle="radian" meshdir="./" inertiagrouprange="1 1" />
  <option integrator="implicitfast" cone="elliptic" impratio="100" timestep="0.002">
    <flag warmstart="enable" nativeccd="enable" multiccd="enable" />
  </option>
  <asset>
    <!-- visual -->
    <mesh name="palm_vis" file="robot_meshes/visual/palm_vis.obj"/>

    <!-- collisions -->
     <mesh name="palm_part0" file="robot_meshes/palm1_part0.obj"/>
     <mesh name="palm_part1" file="robot_meshes/palm1_part1.obj"/>
     <mesh name="palm_part2" file="robot_meshes/palm2_part0.obj"/>
     <mesh name="palm_part3" file="robot_meshes/palm2_part1.obj"/>

    <model name="finger_model_1" file="lego_finger.xml" />
    <model name="finger_model_2" file="lego_finger.xml" />
    <model name="finger_model_3" file="lego_finger.xml" />
    <model name="finger_model_4" file="lego_finger.xml" />
    <model name="finger_model_5" file="lego_finger.xml" />
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="none" />
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2" />
  </asset>
  <default>
    <geom solimp="0.999 0.999 0.001 0.0001 1" solref="0.0001 1" friction=".2" condim="6" margin="0.002" />
    <joint damping="0.03" frictionloss="0.001" armature="0.0015" />
  </default>
  <visual>
    <global azimuth="120" elevation="-20" />
  </visual>
  <worldbody>
    <light name="main_light" pos="0 0 4" dir="0 0 -1" diffuse="1 1 1" specular="0.5 0.5 0.5" />
    <geom name="floor" type="plane" pos="0 0 0" size="10 10 0.1" material="grid" />
    <body name="hand" pos="0 0 0.5" euler="3.1415926 0 0">
      <body name="palm">
        <geom name="palm_geom_0" type="mesh" mesh="palm_part0" group="1" rgba="1 1 1 1" />
        <geom name="palm_geom_1" type="mesh" mesh="palm_part1" group="1" rgba="1 1 1 1" />
        <geom name="palm_geom_2" type="mesh" mesh="palm_part2" group="1" rgba="1 1 1 1" />
        <geom name="palm_geom_3" type="mesh" mesh="palm_part3" group="1" rgba="1 1 1 1" />
        <geom name="palm_vis_geom" type="mesh" mesh="palm_vis" group="0" contype="0" conaffinity="0" />
      </body>
      <frame pos="0 0 0" quat="1.000 0.000000 0.000000 0.000">
        <attach model="finger_model_1" body="finger_root" prefix="f1_" />
      </frame>
      <frame pos="0.025080 0.024835 0.000000" quat="0.961212 0.000000 0.000000 -0.275811">
            <attach model="finger_model_2" body="finger_root" prefix="f2_"/>
        </frame>
      <frame pos="0.041631 0.031106 0.000000" quat="0.763777 0.000000 0.000000 -0.645480">
            <attach model="finger_model_3" body="finger_root" prefix="f3_"/>
        </frame>
      <frame pos="0.052468 0.010662 0.000000" quat="0.578826 0.000000 0.000000 -0.815451">
            <attach model="finger_model_4" body="finger_root" prefix="f4_"/>
        </frame>
      <frame pos="0.059325 -0.005386 0.000000" quat="0.240321 0.000000 0.000000 -0.970694">
        <attach model="finger_model_5" body="finger_root" prefix="f5_"/>
    </frame>
    </body>
    <camera name="fixed" pos="0 -3 2" xyaxes="1 0 0 0 1 2" />

    <body name="obj1" pos="0.08 -0.0 0.58">
      <freejoint name="obj1_free" />
      <!-- <geom name="obj1_sphere" type="sphere" size="0.031" group="1" mass="0.1" friction="0.3 0.01 0.0005" material="cube_mat" /> -->
       <geom name="obj1_cube" type="box" size="0.031 0.031 0.031" group="1" mass="0.1" friction="0.3 0.01 0.0005"/>
    </body>
  </worldbody>
</mujoco>