<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--
Complete MJCF to URDF conversion with correct joint origins and visual compensation.
Source file: meshes/lego_hand/finger1.xml
Macro name: finger1

Key insight: MuJoCo joint positions are absolute coordinates in finger root frame,
but URDF joint origins are relative to parent links. We need to convert between them.

Joint Origin Conversion:
- Each URDF joint origin = (MuJoCo absolute position) - (Parent's revolute joint absolute position)
- For fixed joints, origin is always "0 0 0" as they don't move relative to parent

Visual Compensation:
- Each visual mesh origin = -(Link absolute position) to counteract coordinate frame displacement
- Fixed joints inherit their parent's compensation since they share the same frame
-->
  <xacro:macro name="finger1" params="prefix parent *origin">
    <link name="${prefix}finger_root">
      <inertial>
        <mass value="0.001" />
        <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
      </inertial>
    </link>
    <joint name="${prefix}root_joint" type="fixed">
      <parent link="${parent}" />
      <child link="${prefix}finger_root" />
      <xacro:insert_block name="origin" />
    </joint>
    <link name="${prefix}finger_palm_servo">
      <visual>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_palm_servo_vis.obj" />
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="robot_meshes/finger_palm_servo_part0.obj" />
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01" />
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001" />
      </inertial>
    </link>
    <joint name="${prefix}palm_servo_joint" type="fixed">
      <parent link="${prefix}finger_root" />
      <child link="${prefix}finger_palm_servo" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <link name="${prefix}finger_base">
      <visual>
        <!-- Compensate for joint displacement -->
        <origin xyz="-0.01967 -0.0562 -0.0641" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/visual/finger_base_vis.obj" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="-0.01967 -0.0562 -0.0641" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_base_servo_part0.obj" />
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01" />
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001" />
      </inertial>
    </link>
    <joint name="${prefix}finger_palm_joint" type="revolute">
      <parent link="${prefix}finger_palm_servo" />
      <child link="${prefix}finger_base" />
      <origin xyz="0.01967 0.0562 0.0641" rpy="0 0 0" />
      <axis xyz="0.0 0.0 1.0" />
      <limit lower="-0.698" upper="0.698" effort="10" velocity="1.0" />
      <dynamics damping="1.0" />
    </joint>
    <link name="${prefix}finger_base_lever">
      <visual>
        <!-- Compensate for joint displacement -->
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/visual/finger_base_lever_vis.obj" />
        </geometry>
      </visual>
      <collision name="finger_base_lever_collision_0">
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_base_lever_part0.obj" />
        </geometry>
      </collision>
      <collision name="finger_base_lever_collision_1">
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_base_lever_part1.obj" />
        </geometry>
      </collision>
      <collision name="finger_base_lever_collision_2">
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_base_lever_part2.obj" />
        </geometry>
      </collision>
      


      <inertial>
        <mass value="0.01" />
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001" />
      </inertial>
    </link>
    <link name="${prefix}finger_grammar1_0">
      <!-- Compensation matches the base_lever frame (p_base = 0.03662 0.05775 0.00872) -->
      <visual>
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_grammar1_vis.obj"/>
        </geometry>
        <!-- Optional: color it to verify it's there -->
        <material name="${prefix}stacked_debug"><color rgba="0 1 0 1"/></material>
      </visual>
      <collision>
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_grammar1_part0.obj"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.005"/>
        <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000005"/>
      </inertial>
    </link>
    <joint name="${prefix}grammar1_0_joint" type="fixed">
      <parent link="${prefix}finger_base_lever"/>
      <child  link="${prefix}finger_grammar1_0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <joint name="${prefix}finger_base_joint" type="revolute">
      <parent link="${prefix}finger_base" />
      <child link="${prefix}finger_base_lever" />
      <origin xyz="0.01695 0.00155 -0.05538" rpy="0 0 0" />
      <axis xyz="-0.99975708 -0.0220405 0.0" />
      <limit lower="0" upper="1.5708" effort="10" velocity="1.0" />
      <dynamics damping="1.0" />
    </joint>
    <link name="${prefix}finger_grammar1">
      <visual>
        <!-- use parent (base_lever) compensation -->
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0"/>
        <geometry><mesh filename="robot_meshes/visual/finger_grammar1_vis.obj"/></geometry>
      </visual>
      <collision>
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0"/>
        <geometry><mesh filename="robot_meshes/finger_grammar1_part0.obj"/></geometry>
      </collision>
      <inertial>
        <mass value="0.005"/>
        <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000005"/>
      </inertial>
    </link>

    <joint name="${prefix}grammar1_joint" type="fixed">
      <parent link="${prefix}finger_base_lever"/>
      <child  link="${prefix}finger_grammar1"/>
      <!-- keep the measured offset Δ so kinematics stay identical -->
      <origin xyz="-0.00008 0.00382 -0.00003" rpy="0 0 0"/>
    </joint>

    <!-- === THIRD STACK: finger_grammar1_2 (at P + 2*Δ) === -->
  <link name="${prefix}finger_grammar1_2">
    <visual>
      <!-- keep visual at parent compensation P -->
      <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0"/>
      <geometry>
        <mesh filename="robot_meshes/visual/finger_grammar1_vis.obj"/>
      </geometry>
      <!-- optional: different color to verify -->
      <material name="${prefix}stacked_debug_2"><color rgba="0 0 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0"/>
      <geometry>
        <mesh filename="robot_meshes/finger_grammar1_part0.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000005"/>
    </inertial>
  </link>

  <joint name="${prefix}grammar1_2_joint" type="fixed">
    <parent link="${prefix}finger_base_lever"/>
    <child  link="${prefix}finger_grammar1_2"/>
    <!-- 2 * Δ -->
    <origin xyz="-0.00016 0.00764 -0.00006" rpy="0 0 0"/>
  </joint>

    <link name="${prefix}finger_middle">
  <!-- no visual/collision; tiny inertial so parsers are happy -->
  <inertial>
    <mass value="1e-9"/>
    <inertia ixx="1e-12" ixy="0" ixz="0" iyy="1e-12" iyz="0" izz="1e-12"/>
  </inertial>
</link>

<!-- Keep the original joint name, but make it fixed identity -->
<joint name="${prefix}middle_joint" type="fixed">
  <parent link="${prefix}finger_grammar1_2"/>
  <child  link="${prefix}finger_middle"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<!-- 2) Ghost: finger_middle_lever -->
<link name="${prefix}finger_middle_lever">
  <inertial>
    <mass value="1e-9"/>
    <inertia ixx="1e-12" ixy="0" ixz="0" iyy="1e-12" iyz="0" izz="1e-12"/>
  </inertial>
</link>

<joint name="${prefix}finger_middle_joint" type="revolute">
  <parent link="${prefix}finger_middle"/>
  <child  link="${prefix}finger_middle_lever"/>
  <!-- identity is fine here since these are ghost links -->
  <origin xyz="0 0 0" rpy="0 0 0"/>
  <!-- keep original axis direction to stay consistent -->
  <axis xyz="-0.99976365 -0.02174038 0.0"/>
  <!-- tiny nonzero window so importers don’t weld it -->
  <limit lower="-0.001" upper="0.001" effort="0.05" velocity="0.01"/>
  <!-- strong damping + a touch of friction to kill residual motion -->
  <dynamics damping="10.0" friction="1.0"/>
</joint>

<!-- 3) Ghost: finger_grammar2 -->
<link name="${prefix}finger_grammar2">
  <inertial>
    <mass value="1e-9"/>
    <inertia ixx="1e-12" ixy="0" ixz="0" iyy="1e-12" iyz="0" izz="1e-12"/>
  </inertial>
</link>

<!-- Same as original (it was fixed), identity transform -->
<joint name="${prefix}grammar2_joint" type="fixed">
  <parent link="${prefix}finger_middle_lever"/>
  <child  link="${prefix}finger_grammar2"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

    <link name="${prefix}finger_end">
      <visual>
        <!-- Compensate for joint displacement -->
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/visual/finger_end_vis.obj" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_end_servo_part0.obj" />
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01" />
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001" />
      </inertial>
    </link>
    <joint name="${prefix}end_joint" type="fixed">
      <parent link="${prefix}finger_grammar2" />
      <child link="${prefix}finger_end" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <link name="${prefix}finger_end_lever">
      <visual>
        <!-- Compensate for joint displacement -->
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/visual/finger_end_lever_vis.obj" />
        </geometry>
      </visual>
      <collision name="finger_end_lever_collision_0">
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_end_lever_part0.obj" />
        </geometry>
      </collision>
      <collision name="finger_end_lever_collision_1">
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_end_lever_part1.obj" />
        </geometry>
      </collision>
      <collision name="finger_end_lever_collision_2">
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_end_lever_part2.obj" />
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01" />
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001" />
      </inertial>
    </link>
    <joint name="${prefix}finger_end_joint" type="revolute">
      <parent link="${prefix}finger_end" />
      <child link="${prefix}finger_end_lever" />
      <origin xyz="-0.00072 0.0328 -0.00151" rpy="0 0 0" />
      <axis xyz="-0.99976365 -0.02174038 0.0" />
      <limit lower="0" upper="1.5708" effort="10" velocity="1.0" />
      <dynamics damping="1.0" />
    </joint>
    <link name="${prefix}finger_tip">
      <visual>
        <!-- Compensate for joint displacement -->
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/visual/finger_tip_vis.obj" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0" />
        <geometry>
          <mesh filename="robot_meshes/finger_tip_part0.obj" />
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01" />
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001" />
      </inertial>
    </link>
    <joint name="${prefix}tip_joint" type="fixed">
      <parent link="${prefix}finger_end_lever" />
      <child link="${prefix}finger_tip" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
  </xacro:macro>
</robot>
