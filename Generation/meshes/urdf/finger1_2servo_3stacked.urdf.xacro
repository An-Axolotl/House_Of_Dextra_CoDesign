<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--Auto-converted from modified finger2_3dof.xml
Base segment removed (ghost links), 2 grammar2 elements stacked
Grammar conversion: consolidated within parent links for consistency-->
  
  <xacro:macro name="finger1" params="prefix parent *origin">
    
    <!-- Root link -->
    <link name="${prefix}finger_root">
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      </inertial>
    </link>
    
    <joint name="${prefix}root_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}finger_root"/>
      <xacro:insert_block name="origin"/>
    </joint>
    
    <!-- Palm servo link -->
    <link name="${prefix}finger_palm_servo">
      <visual>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_palm_servo_vis.obj"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="robot_meshes/finger_palm_servo_part0.obj"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    
    <joint name="${prefix}palm_servo_joint" type="fixed">
      <parent link="${prefix}finger_root"/>
      <child link="${prefix}finger_palm_servo"/>
      <origin xyz="0.00000 0.00000 0.00000" rpy="0 0 0"/>
    </joint>
    
    <!-- Ghost: finger_base (base segment removed) -->
    <link name="${prefix}finger_base">
      <inertial>
        <mass value="1e-9"/>
        <inertia ixx="1e-12" ixy="0" ixz="0" iyy="1e-12" iyz="0" izz="1e-12"/>
      </inertial>
    </link>
    
    <joint name="${prefix}finger_palm_joint" type="revolute">
      <parent link="${prefix}finger_palm_servo"/>
      <child link="${prefix}finger_base"/>
      <origin xyz="0.01967 0.05620 0.06410" rpy="0 0 0"/>
      <axis xyz="0.00000 0.00000 1.00000"/>
      <limit lower="-0.698" upper="0.698" effort="10" velocity="1.0"/>
      <dynamics damping="1.0"/>
    </joint>
    
    <!-- Ghost: finger_base_lever (base segment removed) -->
    <link name="${prefix}finger_base_lever">
      <inertial>
        <mass value="1e-9"/>
        <inertia ixx="1e-12" ixy="0" ixz="0" iyy="1e-12" iyz="0" izz="1e-12"/>
      </inertial>
    </link>
    
    <joint name="${prefix}finger_base_joint" type="revolute">
      <parent link="${prefix}finger_base"/>
      <child link="${prefix}finger_base_lever"/>
      <origin xyz="0.01695 0.00155 -0.05538" rpy="0 0 0"/>
      <axis xyz="-0.99976 -0.02204 0.00000"/>
      <!-- Tiny range to effectively disable but prevent welding -->
      <limit lower="-0.001" upper="0.001" effort="0.05" velocity="0.01"/>
      <dynamics damping="10.0" friction="1.0"/>
    </joint>
    
    <!-- Ghost: finger_grammar1 -->
    <link name="${prefix}finger_grammar1">
      <inertial>
        <mass value="1e-9"/>
        <inertia ixx="1e-12" ixy="0" ixz="0" iyy="1e-12" iyz="0" izz="1e-12"/>
      </inertial>
    </link>
    
    <joint name="${prefix}grammar1_joint" type="fixed">
      <parent link="${prefix}finger_base_lever"/>
      <child link="${prefix}finger_grammar1"/>
      <origin xyz="0.00000 0.00000 0.00000" rpy="0 0 0"/>
    </joint>
    
    <!-- finger_middle (functional) -->
    <link name="${prefix}finger_middle">
      <visual>
        <!-- Compensation: use -p₁ since last upstream revolute is base hinge -->
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_middle_vis.obj"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="-0.03662 -0.05775 -0.00872" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_middle_servo_part0.obj"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    
    <joint name="${prefix}middle_joint" type="fixed">
      <parent link="${prefix}finger_grammar1"/>
      <child link="${prefix}finger_middle"/>
      <!-- Offset from original XML: pos="0.00071 -0.03274 0.00141" -->
      <origin xyz="0.00071 -0.03274 0.00141" rpy="0 0 0"/>
    </joint>
    
    <!-- finger_middle_lever with consolidated grammar2 stacks -->
    <link name="${prefix}finger_middle_lever">
      <visual>
        <!-- Compensation: -p₂ since last upstream revolute is middle hinge -->
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_middle_lever_vis.obj"/>
        </geometry>
      </visual>
      
      <!-- Grammar2 stack 0 (base position) -->
      <visual>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_grammar2_vis.obj"/>
        </geometry>
      </visual>
      
      <!-- Grammar2 stack 1 (offset by Δg) -->
      <visual>
        <origin xyz="-0.03599 -0.08674 -0.00746" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_grammar2_vis.obj"/>
        </geometry>
      </visual>
      
      <!-- Collision elements -->
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_middle_lever_part0.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_middle_lever_part1.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_middle_lever_part2.obj"/>
        </geometry>
      </collision>
      
      <!-- Grammar2 collision elements -->
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_grammar2_part0.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03599 -0.08674 -0.00746" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_grammar2_part0.obj"/>
        </geometry>
      </collision>
      
      <inertial>
        <!-- Increased mass to account for consolidated grammar elements -->
        <mass value="0.020"/>
        <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
      </inertial>
    </link>
    
    <joint name="${prefix}finger_middle_joint" type="revolute">
      <parent link="${prefix}finger_middle"/>
      <child link="${prefix}finger_middle_lever"/>
      <!-- Origin from conversion rule: p₂ - p₁ = (0.03591, 0.09056, 0.00743) - (0.03662, 0.05775, 0.00872) -->
      <!-- But adjusted for the modified XML offset -->
      <origin xyz="-0.00071 0.03281 -0.00129" rpy="0 0 0"/>
      <axis xyz="-0.99976 -0.02174 0.00000"/>
      <limit lower="0.0" upper="1.5708" effort="10" velocity="1.0"/>
      <dynamics damping="1.0"/>
    </joint>
    
    <!-- finger_end -->
    <link name="${prefix}finger_end">
      <visual>
        <!-- Compensation: -p₂ since connected through fixed joint from middle_lever -->
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_end_vis.obj"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_end_servo_part0.obj"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    
    <joint name="${prefix}end_joint" type="fixed">
      <parent link="${prefix}finger_middle_lever"/>
      <child link="${prefix}finger_end"/>
      <origin xyz="0.00000 0.00000 0.00000" rpy="0 0 0"/>
    </joint>
    
    <!-- finger_end_lever -->
    <link name="${prefix}finger_end_lever">
      <visual>
        <!-- Compensation: -p₃ since last upstream revolute is end hinge -->
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_end_lever_vis.obj"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_end_lever_part0.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_end_lever_part1.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_end_lever_part2.obj"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    
    <joint name="${prefix}finger_end_joint" type="revolute">
      <parent link="${prefix}finger_end"/>
      <child link="${prefix}finger_end_lever"/>
      <!-- Origin: p₃ - p₂ = (-0.00072, 0.03280, -0.00151) -->
      <origin xyz="-0.00072 0.03280 -0.00151" rpy="0 0 0"/>
      <axis xyz="-0.99976 -0.02174 0.00000"/>
      <limit lower="0.0" upper="1.5708" effort="10" velocity="1.0"/>
      <dynamics damping="1.0"/>
    </joint>
    
    <!-- finger_tip -->
    <link name="${prefix}finger_tip">
      <visual>
        <!-- Compensation: -p₃ -->
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_tip_vis.obj"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_tip_part0.obj"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    
    <joint name="${prefix}tip_joint" type="fixed">
      <parent link="${prefix}finger_end_lever"/>
      <child link="${prefix}finger_tip"/>
      <origin xyz="0.00000 0.00000 0.00000" rpy="0 0 0"/>
    </joint>
    
  </xacro:macro>
</robot>