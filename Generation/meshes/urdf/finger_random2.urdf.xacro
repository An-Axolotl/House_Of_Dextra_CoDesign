      </visual>
      <!-- Grammar2 stack: 4 instances -->
      <visual>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_grammar2_vis.obj"/>
        </geometry>
      </visual>
      <visual>
        <origin xyz="-0.03599 -0.08674 -0.00746" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_grammar2_vis.obj"/>
        </geometry>
      </visual>
      <visual>
        <origin xyz="-0.03607 -0.08292 -0.00749" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_grammar2_vis.obj"/>
        </geometry>
      </visual>
      <visual>
        <origin xyz="-0.03615 -0.07910 -0.00752" rpy="0 0 0"/>
        <geometry>
