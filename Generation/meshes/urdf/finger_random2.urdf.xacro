        <geometry>
          <mesh filename="robot_meshes/finger_middle_lever_part1.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_middle_lever_part2.obj"/>
        </geometry>
      </collision>
      <!-- Grammar2 collisions -->
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_grammar2_part0.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03599 -0.08674 -0.00746" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_grammar2_part0.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03607 -0.08292 -0.00749" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_grammar2_part0.obj"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.03615 -0.07910 -0.00752" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_grammar2_part0.obj"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.03"/>
        <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00003"/>
      </inertial>
    </link>
    <joint name="${prefix}finger_middle_joint" type="revolute">
      <parent link="${prefix}finger_middle"/>
      <child link="${prefix}finger_middle_lever"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="-0.99976 -0.02174 0.00000"/>
      <limit lower="-0.001" upper="0.001" effort="0.05" velocity="0.01"/>
      <dynamics damping="10.0" friction="1.0"/>
    </joint>
    <link name="${prefix}finger_end">
      <visual>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_end_vis.obj"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="-0.03591 -0.09056 -0.00743" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/finger_end_servo_part0.obj"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    <joint name="${prefix}end_joint" type="fixed">
      <parent link="${prefix}finger_middle_lever"/>
      <child link="${prefix}finger_end"/>
      <origin xyz="-0.00024 0.01146 -0.00009" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}finger_end_lever">
      <visual>
        <origin xyz="-0.03519 -0.12336 -0.00592" rpy="0 0 0"/>
        <geometry>
          <mesh filename="robot_meshes/visual/finger_end_lever_vis.obj"/>
